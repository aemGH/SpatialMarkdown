# Spatial Markdown Engine — Environment contract
# Copy this file to .env and fill in real values. Never commit .env.
#
# Only required if you run `npm run gemini` (the live Gemini streaming demo).
# The core library and unit tests do not need any environment variables.

# Google Gemini API key — get one at https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Optional: override the default model. Defaults to gemini-2.0-flash-exp.
# GEMINI_MODEL=gemini-2.0-flash-exp
