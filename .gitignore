# ==========================================================================
# Spatial Markdown Engine — .gitignore
# ==========================================================================

# ---- Dependencies --------------------------------------------------------
node_modules/

# ---- Build output --------------------------------------------------------
dist/
build/
*.tsbuildinfo

# ---- Environment & secrets ----------------------------------------------
# Never commit actual env files. Commit .env.example for the contract.
.env
.env.local
.env.*.local
.env.development
.env.production

# ---- Testing & coverage --------------------------------------------------
coverage/
.nyc_output/
*.lcov
.vitest-cache/

# ---- Logs ----------------------------------------------------------------
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# ---- Editor & IDE --------------------------------------------------------
.vscode/
.idea/
*.swp
*.swo
*~
.project
.classpath
.settings/
*.sublime-project
*.sublime-workspace

# ---- Operating system junk ----------------------------------------------
.DS_Store
.AppleDouble
.LSOverride
._*
Thumbs.db
Desktop.ini
ehthumbs.db

# ---- Temporary / cache ---------------------------------------------------
*.tmp
*.temp
.cache/
.parcel-cache/
.turbo/

# ---- Internal planning docs (not product documentation) -----------------
# These describe HOW the project was built, not HOW to use it.
# Product documentation lives in README.md, LICENSE, and specs/.
project-manifest.md
AGENTS.md
AI_README.md

# ---- Scratch / personal notes -------------------------------------------
scratch/
notes/
TODO.md
NOTES.md
*.scratch.*
test-json.cjs
