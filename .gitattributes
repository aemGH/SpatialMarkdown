# Normalize line endings across platforms.
# All text files use LF in the repo; git converts to native on checkout.
* text=auto eol=lf

# Explicit text files (defensive — covers edge cases)
*.ts        text eol=lf
*.tsx       text eol=lf
*.js        text eol=lf
*.jsx       text eol=lf
*.json      text eol=lf
*.md        text eol=lf
*.html      text eol=lf
*.css       text eol=lf
*.yml       text eol=lf
*.yaml      text eol=lf
*.toml      text eol=lf
*.sh        text eol=lf
*.gitignore text eol=lf
*.env*      text eol=lf

# Binary files — never convert
*.png       binary
*.jpg       binary
*.jpeg      binary
*.gif       binary
*.ico       binary
*.webp      binary
*.woff      binary
*.woff2     binary
*.ttf       binary
*.otf       binary
*.pdf       binary
*.zip       binary
