{
  "name": "@spatial-markdown/engine",
  "version": "0.1.0",
  "description": "High-performance Spatial Markdown layout engine powered by @chenglou/pretext",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "imports": {
    "@chenglou/pretext": "./src/engine/measurement/pretext-fork/layout.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./canvas": {
      "types": "./dist/canvas/index.d.ts",
      "import": "./dist/canvas/index.js",
      "require": "./dist/canvas/index.cjs"
    },
    "./bridge": {
      "types": "./dist/bridge/index.d.ts",
      "import": "./dist/bridge/index.js",
      "require": "./dist/bridge/index.cjs"
    },
    "./ssr": {
      "types": "./dist/ssr/index.d.ts",
      "import": "./dist/ssr/index.js",
      "require": "./dist/ssr/index.cjs"
    },
    "./types": {
      "types": "./dist/types/index.d.ts"
    }
  },
  "sideEffects": false,
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "dev": "vite",
    "showcase": "vite --config vite.showcase.config.ts",
    "gemini": "vite --config vite.gemini.config.ts",
    "build": "vite build && npm run build:quickjs && tsc --emitDeclarationOnly",
    "build:quickjs": "vite build --config vite.quickjs.config.ts && node -e \"require('fs').copyFileSync('dist/quickjs/index.js', 'android/spatial-engine/src/main/assets/quickjs-engine.js')\"",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:bench": "vitest bench",
    "test:coverage": "vitest run --coverage",
    "golden:capture": "vitest run tests/golden/capture-goldens.script.ts",
    "golden:verify": "vitest run tests/golden",
    "typecheck": "tsc --noEmit",
    "lint": "oxlint src/ tests/",
    "format": "prettier --write \"src/**/*.ts\" \"tests/**/*.ts\"",
    "prepublishOnly": "npm run typecheck && npm run test && npm run build"
  },
  "dependencies": {
    "@chenglou/pretext": "^0.0.5"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^3.0.0",
    "canvas": "^3.2.3",
    "happy-dom": "^20.9.0",
    "jsdom": "^29.0.2",
    "oxlint": "^1.51.0",
    "prettier": "^3.5.0",
    "tsx": "^4.21.0",
    "typescript": "^5.8.0",
    "vite": "^6.0.0",
    "vite-plugin-dts": "^4.0.0",
    "vitest": "^3.0.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
